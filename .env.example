# ============================================================
#  autonomous-company-orchestrator — environment configuration
#  Copy to .env and edit. .env is gitignored.
# ============================================================

# ── Backend ─────────────────────────────────────────────────
# "ollama" (default) | "lmstudio"
LLM_BACKEND=lmstudio

# ── Ollama ───────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── LM Studio ────────────────────────────────────────────────
# Enable: LM Studio → Local Server tab → Start Server
LMSTUDIO_HOST=http://localhost:1234/v1

# ============================================================
#  MODEL ASSIGNMENTS — Ollama tags (used when LLM_BACKEND=ollama)
# ============================================================

# Strategic reasoning + planning
MODEL_CEO=qwen3.5:9b-q4_K_M
MODEL_CTO=qwen3.5:9b-q4_K_M
MODEL_DATA_ANALYST=qwen3.5:9b-q4_K_M
MODEL_PRODUCT_MANAGER=qwen3.5:9b-q4_K_M
MODEL_RESEARCHER=qwen3.5:9b-q4_K_M

# Code generation and review
MODEL_DEVELOPER=qwen2.5-coder:14b
MODEL_QA_ENGINEER=qwen2.5-coder:14b
MODEL_DEVOPS_ENGINEER=qwen2.5-coder:14b
MODEL_SECURITY_ENGINEER=qwen2.5-coder:14b

# ============================================================
#  MODEL ASSIGNMENTS — LM Studio IDs (used when LLM_BACKEND=lmstudio)
#
#  Option C — Best balance for 16GB RAM (April 2026)
#
#  Reasoning tier:  lmstudio-community/Qwen3.5-9B-GGUF  (~5.5GB Q4_K_M)
#  Code tier:       lmstudio-community/Qwen2.5-Coder-14B-Instruct-GGUF  (~9GB Q4_K_M)
#
#  In LM Studio:
#    1. Search model name in the Discover tab
#    2. Download Q4_K_M variant
#    3. Start Local Server (port 1234)
#    4. LM Studio auto-loads the model when the API requests it
#
#  Model IDs below = exact identifier shown in LM Studio after download
# ============================================================

# Strategic reasoning + planning — Qwen3.5-9B distilled on Claude Opus 4.6 reasoning traces
# ~5.63GB Q4_K_M | 256K context | 20% fewer reasoning tokens vs base Qwen3.5-9B
# HuggingFace: https://huggingface.co/Jackrong/Qwen3.5-9B-Claude-4.6-Opus-Reasoning-Distilled-v2-GGUF
LMSTUDIO_MODEL_CEO=Jackrong/Qwen3.5-9B-Claude-4.6-Opus-Reasoning-Distilled-v2-GGUF
LMSTUDIO_MODEL_CTO=Jackrong/Qwen3.5-9B-Claude-4.6-Opus-Reasoning-Distilled-v2-GGUF
LMSTUDIO_MODEL_DATA_ANALYST=Jackrong/Qwen3.5-9B-Claude-4.6-Opus-Reasoning-Distilled-v2-GGUF
LMSTUDIO_MODEL_PRODUCT_MANAGER=Jackrong/Qwen3.5-9B-Claude-4.6-Opus-Reasoning-Distilled-v2-GGUF
LMSTUDIO_MODEL_RESEARCHER=Jackrong/Qwen3.5-9B-Claude-4.6-Opus-Reasoning-Distilled-v2-GGUF

# Code generation — Qwen2.5-Coder 7B Instruct Q4_K_M (~4.4GB, 32K context)
# HuggingFace: https://huggingface.co/lmstudio-community/Qwen2.5-Coder-7B-Instruct-GGUF
LMSTUDIO_MODEL_DEVELOPER=lmstudio-community/Qwen2.5-Coder-7B-Instruct-GGUF
LMSTUDIO_MODEL_DEVOPS_ENGINEER=lmstudio-community/Qwen2.5-Coder-7B-Instruct-GGUF
LMSTUDIO_MODEL_SECURITY_ENGINEER=lmstudio-community/Qwen2.5-Coder-7B-Instruct-GGUF

# QA / test generation — DeepSeek-R1-Distill-Qwen-7B Q4_K_M (~4.4GB, 32K context)
# Chain-of-thought reasoning fine-tune on Qwen2.5 — better edge-case coverage than plain coder
# HuggingFace: https://huggingface.co/lmstudio-community/DeepSeek-R1-Distill-Qwen-7B-GGUF
LMSTUDIO_MODEL_QA_ENGINEER=lmstudio-community/DeepSeek-R1-Distill-Qwen-7B-GGUF
# ============================================================
#  WORKFLOW
# ============================================================

# LOG_LEVEL=INFO
# RATE_LIMIT_DELAY=2.0
# COMPANY_AGI_OUTPUT_DIR=output/solutions
# COMPANY_AGI_RUN_TESTS=true
# COMPANY_AGI_STREAMING=true
